# ============================================================
# Liefdesnestje — environment variables
# Copy to .env and fill in. Real .env is gitignored.
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (Railway Postgres) ---
# Local: pnpm dlx @railway/cli@latest run -- will inject; or spin up local Postgres
# Production: Railway injects DATABASE_URL automatically when you attach the plugin.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/liefdesnestje

# --- Auth.js / NextAuth v5 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- Google OAuth (for sign-in) ---
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-railway-subdomain>.up.railway.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Microsoft Graph (for calendar sync) ---
# https://portal.azure.com → App registrations → New registration
# Redirect URI (Web): http://localhost:3000/api/integrations/microsoft/callback
# API permissions (delegated): Calendars.ReadWrite, offline_access, User.Read
# Client secret: Certificates & secrets → New client secret
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common

# --- Google Calendar (future; stubbed in v1) ---
# Same OAuth client as sign-in can be reused by adding Calendar scope.
GOOGLE_CALENDAR_ENABLED=false

# --- Encryption (for OAuth tokens at rest) ---
# 32-byte hex string. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# --- Webhook shared secret ---
# Passed as header by Graph/Google push notifications we configure.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# --- File uploads (Railway Volume in prod) ---
UPLOAD_DIR=/data/uploads
